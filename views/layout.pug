doctype html
html
  head
    title Lab System
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")

    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")

    style.
      body {
        background: #f4f6f9;
      }
      .sidebar {
        width: 220px;
        height: 100vh;
        position: fixed;
        background: #111827;
        color: white;
        padding: 20px;
      }
      .sidebar a {
        display: block;
        color: #ccc;
        padding: 10px;
        text-decoration: none;
        border-radius: 8px;
      }
      .sidebar a:hover {
        background: #374151;
        color: white;
      }
      .content {
        margin-left: 240px;
        padding: 20px;
      }

  body

    .sidebar
      h4 Lab System
      hr
      a(href="/dashboard") Dashboard
      a(href="/inventaris") Inventaris
      a(href="/logout") Logout

    .content
      block content